# ─── Setup checklist (Ask CTO + dashboards) ─────────────────────────
# 1. Copy this file to `.env.local` and fill values.
# 2. NEXT_PUBLIC_DJANGO_URL → your Django API (same host the browser can reach).
# 3. AGENTS_API_URL → orchestrator HTTP (churchagents): run `python orchestrator_server.py`
#    Default port 8001. Restart `npm run dev` after changing env.
# 4. In churchagents `.env` set AGENT_JWT_EMAIL, AGENT_JWT_PASSWORD, DJANGO_BASE_URL
#    so the orchestrator can call Django for live context (same credentials can work).

# Public URL of Django (browser + Next server use this base)
NEXT_PUBLIC_DJANGO_URL=http://localhost:8000

# Server-only: must match a real Django user (platform admin is best for this dashboard)
# Use the SAME values you use in churchagents .env: AGENT_JWT_EMAIL / AGENT_JWT_PASSWORD
DJANGO_AGENT_EMAIL=padmin@churchsaas.com
# If the password contains #, use double quotes: DJANGO_AGENT_PASSWORD="YourPass#123"
DJANGO_AGENT_PASSWORD=your-password-here

# Optional: only if the same email exists for two churches (disambiguate login)
# DJANGO_AGENT_CHURCH_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# REQUIRED for Ask CTO (orchestrator) and Subscriptions "Remind" (orchestrator POST /renewal-reminder)
AGENTS_API_URL=http://localhost:8001

# Optional: Observability sidebar link to LangSmith (project or home URL)
# NEXT_PUBLIC_LANGSMITH_UI_URL=https://smith.langchain.com/o/your-org/projects/p/your-project
